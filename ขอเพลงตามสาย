<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ระบบขอเพลงตามสายโรงเรียน</title>
  <style>
    * {
      box-sizing: border-box;
      font-family: 'Prompt', 'Sarabun', Arial, sans-serif;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background: linear-gradient(135deg, #0f172a, #1d4ed8, #facc15);
      color: #111827;
    }

    .page {
      min-height: 100vh;
      padding: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .app {
      width: min(1120px, 100%);
      background: rgba(255, 255, 255, 0.94);
      border-radius: 28px;
      box-shadow: 0 28px 70px rgba(0, 0, 0, 0.35);
      overflow: hidden;
      backdrop-filter: blur(20px);
    }

    header {
      padding: 28px;
      background: linear-gradient(135deg, #1e3a8a, #2563eb);
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .brand h1 {
      margin: 0;
      font-size: clamp(26px, 4vw, 42px);
      letter-spacing: -0.5px;
    }

    .brand p {
      margin: 8px 0 0;
      color: #dbeafe;
      font-size: 15px;
    }

    .badge {
      padding: 10px 16px;
      border-radius: 999px;
      background: rgba(250, 204, 21, 0.95);
      color: #1e293b;
      font-weight: 800;
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
    }

    nav {
      display: flex;
      gap: 10px;
      padding: 18px 24px 0;
      flex-wrap: wrap;
    }

    nav button, .btn {
      border: 0;
      cursor: pointer;
      padding: 12px 18px;
      border-radius: 16px;
      font-weight: 800;
      background: #e5e7eb;
      color: #1f2937;
      transition: 0.2s;
    }

    nav button.active, .btn.primary {
      background: linear-gradient(135deg, #2563eb, #1e40af);
      color: white;
      box-shadow: 0 12px 28px rgba(37, 99, 235, 0.32);
    }

    nav button:hover, .btn:hover {
      transform: translateY(-2px);
    }

    main {
      padding: 24px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 24px;
    }

    @media (max-width: 860px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }

    .card {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 24px;
      padding: 24px;
      box-shadow: 0 16px 35px rgba(15, 23, 42, 0.08);
    }

    .card h2 {
      margin: 0 0 14px;
      color: #1e3a8a;
    }

    label {
      display: block;
      margin: 14px 0 7px;
      font-weight: 800;
      color: #374151;
    }

    input, textarea, select {
      width: 100%;
      padding: 13px 14px;
      border-radius: 15px;
      border: 1px solid #cbd5e1;
      font-size: 15px;
      outline: none;
      background: #f8fafc;
    }

    input:focus, textarea:focus, select:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
      background: white;
    }

    textarea {
      min-height: 92px;
      resize: vertical;
    }

    .btn-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .btn.danger {
      background: #fee2e2;
      color: #991b1b;
    }

    .btn.success {
      background: #dcfce7;
      color: #166534;
    }

    .btn.warning {
      background: #fef3c7;
      color: #92400e;
    }

    .song-list {
      display: grid;
      gap: 14px;
      margin-top: 16px;
    }

    .song-item {
      border: 1px solid #e5e7eb;
      border-radius: 20px;
      padding: 16px;
      background: #f8fafc;
      position: relative;
    }

    .song-title {
      font-size: 18px;
      font-weight: 900;
      color: #111827;
      margin-bottom: 6px;
    }

    .meta {
      color: #4b5563;
      font-size: 14px;
      line-height: 1.7;
    }

    .status {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 900;
      margin-top: 10px;
    }

    .pending { background: #fef3c7; color: #92400e; }
    .approved { background: #dcfce7; color: #166534; }
    .rejected { background: #fee2e2; color: #991b1b; }
    .played { background: #dbeafe; color: #1d4ed8; }

    .hidden {
      display: none !important;
    }

    .login-box {
      max-width: 420px;
      margin: 0 auto;
    }

    .admin-toolbar {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 16px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 18px;
    }

    @media (max-width: 700px) {
      .stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .stat {
      border-radius: 18px;
      padding: 16px;
      background: linear-gradient(135deg, #eff6ff, #ffffff);
      border: 1px solid #dbeafe;
    }

    .stat b {
      font-size: 26px;
      color: #1d4ed8;
      display: block;
    }

    .toast {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.72);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: 0.25s;
      z-index: 999;
      padding: 20px;
    }

    .toast-box {
      background: white;
      width: min(680px, 95%);
      border-radius: 28px;
      padding: 36px;
      text-align: center;
      box-shadow: 0 30px 80px rgba(0,0,0,0.35);
      transform: scale(0.9);
      transition: 0.25s;
    }

    .toast-box h2 {
      margin: 0 0 12px;
      font-size: clamp(28px, 5vw, 48px);
      color: #dc2626;
    }

    .toast-box p {
      margin: 0 0 24px;
      font-size: clamp(16px, 2vw, 22px);
      color: #334155;
      line-height: 1.6;
    }

    .toast-box button {
      border: 0;
      background: linear-gradient(135deg, #2563eb, #1e40af);
      color: white;
      padding: 14px 28px;
      border-radius: 16px;
      font-size: 18px;
      font-weight: 800;
      cursor: pointer;
    }

    .toast.show {
      opacity: 1;
      pointer-events: auto;
    }

    .toast.show .toast-box {
      transform: scale(1);
    }

    .toast.small {
      inset: auto 18px 18px auto;
      background: transparent;
      padding: 0;
      align-items: flex-end;
      justify-content: flex-end;
    }

    .toast.small .toast-box {
      width: auto;
      min-width: 280px;
      max-width: 380px;
      padding: 16px 20px;
      border-radius: 14px;
      text-align: left;
      background: rgba(17, 24, 39, 0.96);
      color: white;
      box-shadow: 0 18px 40px rgba(0,0,0,0.35);
    }

    .toast.small .toast-box h2 {
      font-size: 16px;
      color: white;
      margin: 0;
    }

    .toast.small .toast-box p {
      font-size: 14px;
      margin: 6px 0 0;
      color: #d1d5db;
      line-height: 1.4;
    }

    .toast.small .toast-box button {
      display: none;
    }

    .empty {
      text-align: center;
      color: #64748b;
      padding: 28px;
      border: 2px dashed #cbd5e1;
      border-radius: 20px;
      background: #f8fafc;
    }
  

    .admin-corner {
      position: fixed;
      right: 18px;
      top: 18px;
      z-index: 30;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 0;
      cursor: pointer;
      background: rgba(15, 23, 42, 0.78);
      color: white;
      font-size: 20px;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.32);
      backdrop-filter: blur(12px);
      transition: 0.2s;
    }

    .admin-corner:hover {
      transform: scale(1.08);
      background: #1e3a8a;
    }
  </style>
</head>
<body>
  <button class="admin-corner" onclick="showPage('admin')" title="หลังบ้าน">⚙️</button>
  <div class="page">
    <div class="app">
      <header>
        <div class="brand">
          <h1>🎧 ระบบขอเพลงตามสายโรงเรียน</h1>
          <p>ส่งคำขอเพลง ตรวจสอบสถานะ และจัดการหลังบ้านได้ในที่เดียว</p>
        </div>
        <div class="badge">School Radio Request</div>
      </header>

      <nav>
        <button id="requestTab" class="active" onclick="showPage('request')">หน้า ขอเพลง</button>
        <button id="statusTab" onclick="showPage('status')">ตรวจสอบสถานะ</button>
      </nav>

      <main>
        <section id="requestPage" class="grid">
          <div class="card">
            <h2>ส่งคำขอเพลง</h2>
            <form id="songForm">
              <label>ชื่อผู้ขอ</label>
              <input id="studentName" placeholder="เช่น ด.ช.ต้นกล้า" required />

              <label>ชั้น / ห้อง</label>
              <input id="classRoom" placeholder="เช่น ม.3/1" required />

              <label>ลิงก์เพลง (YouTube / Spotify)</label>
              <input id="songLink" type="url" placeholder="https://youtube.com/..." required />

              <button class="btn primary" type="submit">ส่งคำขอเพลง</button>
            </form>
          </div>

          <div class="card">
            <h2>กติกาการขอเพลง</h2>
            <div class="meta">
              ✅ ใช้ถ้อยคำสุภาพในการส่งคำขอเพลง<br>
              ✅ เพลงที่ส่งเข้ามาต้องเหมาะสมกับบริบทของสถานศึกษา<br>
              ✅ แอดมินจะตรวจสอบความเหมาะสมของเพลงก่อนอนุมัติทุกครั้ง<br>
              ✅ คำขออาจถูกปฏิเสธหากเนื้อหาไม่เหมาะสมหรือไม่สามารถเปิดได้<br>
              ✅ ตรวจสอบสถานะได้จากชื่อผู้ขอหรือ URL ลิงก์เพลง
            </div>
          </div>
        </section>

        <section id="statusPage" class="card hidden">
          <h2>ตรวจสอบสถานะคำขอเพลง</h2>
          <label>ค้นหาด้วยชื่อผู้ขอ / ลิงก์เพลง</label>
          <input id="statusSearch" placeholder="พิมพ์ชื่อผู้ขอหรือลิงก์เพลง..." oninput="renderStatusList()" />
          <div id="statusList" class="song-list"></div>
        </section>

        <section id="adminPage" class="hidden">
          <div id="loginBox" class="card login-box">
            <h2>เข้าสู่ระบบหลังบ้าน</h2>
            <label>รหัสผ่านแอดมิน</label>
            <input id="adminPassword" type="password" placeholder="ใส่รหัสผ่าน" />
            <div class="btn-row">
              <button class="btn primary" onclick="loginAdmin()">เข้าสู่ระบบ</button>
            </div>
          </div>

          <div id="adminPanel" class="hidden">
            <div class="card">
              <div class="admin-toolbar">
                <h2>หลังบ้านจัดการคำขอเพลง</h2>
                <div class="btn-row">
                  <button type="button" class="btn warning" onclick="toggleRequestStatus()" id="toggleRequestBtn">ปิดรับคำขอเพลง</button>
                  <button type="button" class="btn danger" onclick="clearAllRequests()">ล้างข้อมูลทั้งหมด</button>
                  <button type="button" class="btn" onclick="logoutAdmin()">ออกจากระบบ</button>
                </div>
              </div>

              <div class="stats">
                <div class="stat"><b id="countAll">0</b>ทั้งหมด</div>
                <div class="stat"><b id="countPending">0</b>รออนุมัติ</div>
                <div class="stat"><b id="countApproved">0</b>อนุมัติ</div>
                <div class="stat"><b id="countPlayed">0</b>เปิดแล้ว</div>
              </div>

              <label>กรองสถานะ</label>
              <select id="filterStatus" onchange="renderAdminList()">
                <option value="all">ทั้งหมด</option>
                <option value="pending">รออนุมัติ</option>
                <option value="approved">อนุมัติ</option>
                <option value="rejected">ปฏิเสธ</option>
                <option value="played">เปิดแล้ว</option>
              </select>

              <div id="adminList" class="song-list"></div>
            </div>
          </div>
        </section>
      </main>
    </div>
  </div>

  <div id="toast" class="toast">
    <div class="toast-box">
      <h2 id="toastTitle">แจ้งเตือน</h2>
      <p id="toastMessage"></p>
      <button type="button" onclick="closeToast()">ปิด</button>
    </div>
  </div>

  <script>
    const ADMIN_PASSWORD = 'MP1401';
    const STORAGE_KEY = 'school_song_requests_v1';
    const REQUEST_STATUS_KEY = 'school_song_request_open';
    const DISCORD_WEBHOOK_URL = 'https://discord.com/api/webhooks/1509160198302994482/9fnJRhR5hnShuj5HOQ1wEMDvRK8hZUjG5ioNXKUzFgaX9TockAZ6hDLvyzK0UOu_kTYI';

    const statusText = {
      pending: 'รออนุมัติ',
      approved: 'อนุมัติแล้ว',
      rejected: 'ไม่อนุมัติ',
      played: 'เปิดเพลงแล้ว'
    };

    function isRequestOpen() {
      return localStorage.getItem(REQUEST_STATUS_KEY) !== 'closed';
    }

    function getRequests() {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    }

    function saveRequests(data) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    }

    function showToast(text, title = 'แจ้งเตือน', type = 'big') {
      const toast = document.getElementById('toast');
      document.getElementById('toastTitle').textContent = title;
      document.getElementById('toastMessage').textContent = text;
      toast.classList.toggle('small', type === 'small');
      toast.classList.add('show');
    }

    function closeToast() {
      document.getElementById('toast').classList.remove('show');
    }

    function showPage(page) {
      document.getElementById('requestPage').classList.toggle('hidden', page !== 'request');
      document.getElementById('statusPage').classList.toggle('hidden', page !== 'status');
      document.getElementById('adminPage').classList.toggle('hidden', page !== 'admin');

      document.getElementById('requestTab').classList.toggle('active', page === 'request');
      document.getElementById('statusTab').classList.toggle('active', page === 'status');

      if (page === 'status') renderStatusList();
      if (page === 'admin') renderAdminList();
    }

    document.getElementById('songForm').addEventListener('submit', function(e) {
      e.preventDefault();
      if (!isRequestOpen()) {
        showToast('ระบบปิดรับคำขอเพลงชั่วคราว กรุณาติดต่อแอดมินหรือกลับมาใหม่ภายหลัง', '🔴 ปิดรับคำขอเพลง');
        return;
      }

      const request = {
        id: String(Date.now()),
        studentName: document.getElementById('studentName').value.trim(),
        classRoom: document.getElementById('classRoom').value.trim(),
        
        songLink: document.getElementById('songLink').value.trim(),
        
        status: 'pending',
        createdAt: new Date().toLocaleString('th-TH')
      };

      const requests = getRequests();
      requests.unshift(request);
      saveRequests(requests);
      sendDiscordNotification(request);

      this.reset();
      showToast('ส่งคำขอเพลงเรียบร้อยแล้ว');
      renderStatusList();
      renderAdminList();
    });

    function songCard(item, isAdmin = false) {
      const link = item.songLink ? `<br>🔗 <a href="${escapeHTML(item.songLink)}" target="_blank">เปิดลิงก์เพลง</a>` : '';
      const adminButtons = isAdmin ? `
        <div class="btn-row">
          <button type="button" class="btn warning" data-action="status" data-id="${escapeHTML(item.id)}" data-status="pending">รออนุมัติ</button>
          <button type="button" class="btn success" data-action="status" data-id="${escapeHTML(item.id)}" data-status="approved">อนุมัติ</button>
          <button type="button" class="btn danger" data-action="status" data-id="${escapeHTML(item.id)}" data-status="rejected">ปฏิเสธ</button>
          <button type="button" class="btn primary" data-action="status" data-id="${escapeHTML(item.id)}" data-status="played">เปิดแล้ว</button>
          <button type="button" class="btn danger" data-action="delete" data-id="${escapeHTML(item.id)}">ลบ</button>
        </div>` : '';

      return `
        <div class="song-item">
          <div class="song-title">🎵 คำขอเพลงจาก ${escapeHTML(item.studentName)}</div>
          <div class="meta">
            👤 ผู้ขอ: ${escapeHTML(item.studentName)} | 🏫 ${escapeHTML(item.classRoom)}<br>
            🕒 ส่งเมื่อ: ${escapeHTML(item.createdAt)}
            ${link}
          </div>
          <span class="status ${item.status}">${statusText[item.status]}</span>
          ${adminButtons}
        </div>
      `;
    }

    function renderStatusList() {
      const keyword = (document.getElementById('statusSearch')?.value || '').toLowerCase();
      const list = getRequests().filter(item => {
        const text = `${item.studentName} ${item.songLink}`.toLowerCase();
        return text.includes(keyword);
      });

      document.getElementById('statusList').innerHTML = list.length
        ? list.map(item => songCard(item)).join('')
        : `<div class="empty">ยังไม่มีรายการคำขอเพลง</div>`;
    }

    function sendDiscordNotification(request) {
      if (!DISCORD_WEBHOOK_URL || DISCORD_WEBHOOK_URL.includes('ใส่ลิงก์')) return;

      fetch(DISCORD_WEBHOOK_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          content:
`📢 มีคำขอเพลงใหม่ในระบบตามสายโรงเรียน

👤 ผู้ขอ: ${request.studentName}
🏫 ชั้น/ห้อง: ${request.classRoom}
🔗 ลิงก์เพลง: ${request.songLink}
🕒 เวลา: ${request.createdAt}
📌 สถานะ: รออนุมัติ`
        })
      }).catch(error => {
        console.error('Discord notification error:', error);
      });
    }

    function loginAdmin() {
      const pass = document.getElementById('adminPassword').value;
      if (pass === ADMIN_PASSWORD) {
        sessionStorage.setItem('admin_login', 'yes');
        document.getElementById('loginBox').classList.add('hidden');
        document.getElementById('adminPanel').classList.remove('hidden');
        renderAdminList();
        showToast('เข้าสู่ระบบหลังบ้านสำเร็จ', '✅ สำเร็จ', 'small');
        setTimeout(() => closeToast(), 2200);
      } else {
        window.alert('รหัสผ่านไม่ถูกต้อง');
      }
    }

    function logoutAdmin() {
      sessionStorage.removeItem('admin_login');
      document.getElementById('loginBox').classList.remove('hidden');
      document.getElementById('adminPanel').classList.add('hidden');
      document.getElementById('adminPassword').value = '';
    }

    function toggleRequestStatus() {
      const current = isRequestOpen();
      localStorage.setItem(REQUEST_STATUS_KEY, current ? 'closed' : 'open');
      renderAdminList();
    }

    function renderAdminList() {
      if (sessionStorage.getItem('admin_login') === 'yes') {
        document.getElementById('loginBox').classList.add('hidden');
        document.getElementById('adminPanel').classList.remove('hidden');
      }

      const requests = getRequests();
      const filter = document.getElementById('filterStatus')?.value || 'all';
      const filtered = filter === 'all' ? requests : requests.filter(item => item.status === filter);

      document.getElementById('countAll').textContent = requests.length;
      document.getElementById('countPending').textContent = requests.filter(i => i.status === 'pending').length;
      document.getElementById('countApproved').textContent = requests.filter(i => i.status === 'approved').length;
      document.getElementById('countPlayed').textContent = requests.filter(i => i.status === 'played').length;

      const toggleBtn = document.getElementById('toggleRequestBtn');
      if (toggleBtn) {
        toggleBtn.textContent = isRequestOpen() ? 'ปิดรับคำขอเพลง' : 'เปิดรับคำขอเพลง';
      }

      const adminList = document.getElementById('adminList');
      if (adminList) {
        adminList.innerHTML = filtered.length
          ? filtered.map(item => songCard(item, true)).join('')
          : `<div class="empty">ไม่พบรายการตามสถานะที่เลือก</div>`;
      }
    }

    function updateStatus(id, status) {
      const requests = getRequests().map(item => String(item.id) === String(id) ? { ...item, status } : item);
      saveRequests(requests);
      
      renderAdminList();
      renderStatusList();
    }

    function deleteRequest(id) {
      const ok = window.confirm('ต้องการลบคำขอนี้ใช่หรือไม่?');
      if (!ok) return;

      const requests = getRequests().filter(item => String(item.id) !== String(id));
      saveRequests(requests);
      
      renderAdminList();
      renderStatusList();
    }

    document.getElementById('adminList').addEventListener('click', function(e) {
      const button = e.target.closest('button[data-action]');
      if (!button) return;

      const action = button.dataset.action;
      const id = button.dataset.id;

      if (action === 'delete') {
        deleteRequest(id);
      }

      if (action === 'status') {
        updateStatus(id, button.dataset.status);
      }
    });

    function clearAllRequests() {
      const ok = window.confirm('ต้องการล้างข้อมูลคำขอเพลงทั้งหมดใช่หรือไม่?');
      if (!ok) return;

      localStorage.removeItem(STORAGE_KEY);

      const filterStatus = document.getElementById('filterStatus');
      if (filterStatus) filterStatus.value = 'all';

      const statusSearch = document.getElementById('statusSearch');
      if (statusSearch) statusSearch.value = '';

      document.getElementById('countAll').textContent = '0';
      document.getElementById('countPending').textContent = '0';
      document.getElementById('countApproved').textContent = '0';
      document.getElementById('countPlayed').textContent = '0';
      document.getElementById('adminList').innerHTML = `<div class="empty">ยังไม่มีรายการคำขอเพลง</div>`;
      document.getElementById('statusList').innerHTML = `<div class="empty">ยังไม่มีรายการคำขอเพลง</div>`;

      
    }

    function escapeHTML(text) {
      return String(text)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    renderStatusList();
    renderAdminList();
  </script>
</body>
</html>
